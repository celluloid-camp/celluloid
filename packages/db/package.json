{
  "name": "@celluloid/db",
  "version": "3.5.0",
  "license": "MIT",
  "private": true,
  "type": "module",
  "main": "./index.ts",
  "types": "./index.ts",
  "scripts": {
    "build": "bun generate && bun bundle",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "push": "drizzle-kit push",
    "migrate": "bun --env-file ../../apps/web/.env migrate.ts",
    "studio": "drizzle-kit studio",
    "generate": "drizzle-kit generate",
    "bundle": "bun build --bytecode --minify --sourcemap --target=bun --compile ./migrate.ts --outfile=./dist/migrate",
    "drop": "drizzle-kit drop",
    "seed": "bun run seed.ts"
  },
  "devDependencies": {
    "@celluloid/typescript-config": "workspace:*",
    "@types/randomcolor": "^0.5.7",
    "@faker-js/faker": "^10.3.0",
    "@types/dotenv": "^8.2.3",
    "@types/node-fetch": "^2.6.7",
    "@types/pg": "^8.16.0",
    "dotenv": "^17.3.1",
    "drizzle-kit": "catalog:",
    "typescript": "catalog:"
  },
  "dependencies": {
    "@celluloid/vision": "workspace:*",
    "@celluloid/peertube": "workspace:*",
    "@t3-oss/env-nextjs": "catalog:",
    "drizzle-orm": "catalog:",
    "pg": "^8.18.0",
    "randomcolor": "^0.6.2",
    "zod": "catalog:"
  }
}
