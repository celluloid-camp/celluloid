{
  "name": "celluloid",
  "version": "3.5.0",
  "author": "Younes Benaomar <younes.benaomar@gmail.com>",
  "repository": "http://github.com/celluloid-edu/celluloid",
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@playwright/test": "^1.52.0",
    "@release-it/conventional-changelog": "^10.0.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.14.1",
    "conventional-changelog-conventionalcommits": "9.1.0",
    "lefthook": "^2.1.4",
    "release-it": "^19.0.5",
    "turbo": "^2.8.19",
    "typescript": "^5.9.3"
  },
  "catalog": {
    "@t3-oss/env-nextjs": "^0.13.8",
    "@trpc/server": "^11.13.4",
    "@types/node": "^25.3.5",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "better-auth": "^1.4.18",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "dotenv-cli": "^11.0.0",
    "lodash": "^4.17.23",
    "notistack": "^3.0.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "server-only": "^0.0.1",
    "superjson": "^2.2.6",
    "typescript": "^5.9.3",
    "workflow": "4.2.0-beta.71",
    "zod": "^4.3.6",
    "drizzle-orm": "^0.45.1",
    "pino": "^10.3.1",
    "drizzle-kit": "^0.31.9",
    "@workflow/world-postgres": "4.1.0-beta.46",
    "@celluloid/vision-api": "^1.5.0"
  },
  "description": "Celluloid helps students and teachers to interact by annotating online educational videos",
  "engines": {
    "node": ">=20"
  },
  "ignoreScripts": [
    "unrs-resolver"
  ],
  "license": "MIT",
  "packageManager": "bun@1.3.8",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "clean:all": "turbo run clean && git clean -xdf .cache .turbo dist node_modules ",
    "build": "turbo run build",
    "format": "biome check --fix",
    "prepare": "lefthook install",
    "test": "turbo run test",
    "test:watch": "bunx vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "--shortcuts to run commands in workspaces--": "",
    "web": "bun run --filter web",
    "auth": "bun run --filter auth",
    "db": "bun run --filter @celluloid/db",
    "docker:build": "docker buildx build -f apps/web/Dockerfile -t celluloid-web .",
    "docker:build:db-migrate": "docker buildx build -f packages/db/Dockerfile -t celluloid-db-migrate .",
    "docker:run": "docker run -it --rm --env-file ./apps/web/.env -p 3000:3000 celluloid-web",
    "docker:run:db-migrate": "docker run -it --rm --env-file ./apps/web/.env celluloid-db-migrate",
    "release": "bun run release-it"
  },
  "trustedDependencies": [
    "@parcel/watcher",
    "@swc/core",
    "@tailwindcss/oxide",
    "canvas",
    "core-js",
    "esbuild",
    "protobufjs",
    "sharp",
    "vue-demi"
  ],
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@workflow/world-postgres": "catalog:"
  }
}
